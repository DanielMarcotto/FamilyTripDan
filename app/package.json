    "expo-blur": "~15.0.7",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.17",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linear-gradient": "~15.0.7",
