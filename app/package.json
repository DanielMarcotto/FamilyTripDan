{
  "name": "app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:simulator": "bash scripts/run-ios-simulator.sh",
    "prebuild": "npx expo prebuild --clean",
    "web": "expo start --web",
    "lint": "expo lint",
    "devclient": "npx expo start --dev-client",
    "javaV": "source ~/.zshrc",
    "buildAndroidLocal": "eas build --platform android --profile development --local",
    "buildAndroidProduction": "node scripts/increment-version.js && eas build --platform android --profile production",
    "buildAndroidProductionLocal": "eas build --platform android --profile production --local",
    "buildIosProduction": "node scripts/increment-version.js && eas build --platform ios --profile production",
    "buildIosProductionLocal": "eas build --platform ios --profile production --local",
    "submitIosProduction": "eas submit --platform ios --profile production",
    "bootsim": "xcrun simctl boot 7D070117-0A69-4472-A14B-99C9386200E8",
    "preview:icons": "python3 scripts/preview_android_icons.py",
    "icons:round": "python3 scripts/generate_android_icons_round.py"
  },
  "dependencies": {
    "@callstack/liquid-glass": "^0.6.0",
